# Copy this file to `.env` and fill in your values.
# Do NOT commit your real `.env` to source control.

# OpenAI API key
OPENAI_API_KEY="your-openai-api-key-here"

# Preferred OpenAI model (optional). If not set, defaults to "gpt-4".
# Set to a model you have access to, e.g. "gpt-4o-mini" or "gpt-4o".
OPENAI_MODEL="gpt-4"

# Fallback model to use if preferred model is unavailable.
OPENAI_FALLBACK_MODEL="gpt-4o-mini"
